# ArenaPulse Django Service Environment Variables
# Copy this file to .env and fill in your actual values

SECRET_KEY=your_django_secret_key_here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/esports_db?retryWrites=true&w=majority
EXPRESS_API_URL=http://localhost:5000
